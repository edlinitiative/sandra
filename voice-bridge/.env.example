# ═══════════════════════════════════════════════════════════════
# Sandra Voice Bridge — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0

# ── WhatsApp (same WABA as the main Sandra app) ──────────────
WHATSAPP_PHONE_NUMBER_ID=975039899036234
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
# Token used when subscribing the `calls` field in Meta webhook settings
WHATSAPP_VOICE_VERIFY_TOKEN=sandra-voice-verify-2026
WHATSAPP_API_VERSION=v19.0

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_VOICE=alloy

# ── Sandra persona (optional override) ───────────────────────
# SANDRA_INSTRUCTIONS=You are Sandra...

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
