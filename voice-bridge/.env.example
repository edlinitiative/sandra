# ═══════════════════════════════════════════════════════════════
# Sandra Voice Bridge — Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0

# ── WhatsApp (same WABA as the main Sandra app) ──────────────
# Found in Meta Developer Console → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Token you invent; must match what you enter in Meta's webhook subscription UI
WHATSAPP_VOICE_VERIFY_TOKEN=sandra-voice-verify-2026
WHATSAPP_API_VERSION=v19.0

# Meta App Secret — used to verify webhook payload signatures (X-Hub-Signature-256)
# META_APP_SECRET=

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# Available voices: alloy, echo, fable, onyx, nova, shimmer
OPENAI_VOICE=alloy

# ── Sandra persona (optional override) ───────────────────────
# SANDRA_INSTRUCTIONS=You are Sandra, an AI voice assistant for EdLight...

# ── Escalation ────────────────────────────────────────────────
# Comma-separated WhatsApp numbers (with country code, no +) that
# receive a notification when a caller requests a real person.
ESCALATION_PHONE_NUMBERS=

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error
