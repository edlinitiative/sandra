# Sandra Voice Bridge — Caddy reverse proxy
# Automatic TLS via Let's Encrypt (HTTP-01 challenge on port 80)
# DNS record: voice.edlight.org → VM public IP

voice.edlight.org {
    # Forward all traffic to the voice-bridge container on the internal Docker network
    reverse_proxy voice-bridge:3001

    # Structured access logs
    log {
        output file /var/log/caddy/access.log {
            roll_size     50mb
            roll_keep     5
            roll_keep_for 720h
        }
        format json
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        -Server
    }
}
