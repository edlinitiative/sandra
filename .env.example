# =============================================================================
# Sandra — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# =============================================================================

# ── Core Application ──────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_SECRET=change-me-to-a-random-secret

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://sandra:sandra@localhost:5432/sandra?schema=public

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-token
GITHUB_ORG=edlinitiative

# ── Vector Store ──────────────────────────────────────────────────────────────
# For future production use (e.g., Pinecone, Weaviate, Qdrant)
VECTOR_STORE_PROVIDER=memory
# VECTOR_STORE_URL=
# VECTOR_STORE_API_KEY=

# ── Channel Integrations ─────────────────────────────────────────────────────
# WhatsApp (Meta Business API)
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_VERIFY_TOKEN=

# Instagram (Meta Graph API)
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_VERIFY_TOKEN=

# Email (SMTP / SendGrid / etc.)
# EMAIL_PROVIDER=smtp
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# EMAIL_FROM=sandra@edlight.org

# Voice (future — Twilio, etc.)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
