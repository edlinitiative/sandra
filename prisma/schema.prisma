// =============================================================================
// Sandra — Prisma Schema
// =============================================================================
// PostgreSQL-ready schema for the Sandra AI platform.
// Run `npx prisma db push` or `npx prisma migrate dev` to apply.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum MessageRole {
  user
  assistant
  system
  tool
}

enum SyncStatus {
  not_indexed
  indexing
  indexed
  error
}

enum ActionStatus {
  pending
  approved
  rejected
  executed
  failed
}

enum UserRole {
  guest
  student
  educator
  admin
}

// ── Users ────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  externalId     String?   @unique // ID from external auth provider
  name           String?
  email          String?   @unique
  role           UserRole  @default(guest)
  language       String    @default("en") // en | fr | ht
  channel        String    @default("web") // web | whatsapp | instagram | email | voice
  metadata       Json?     // Flexible extra data
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sessions       Session[]
  memories       Memory[]
  enrollments    Enrollment[]
  certificates   Certificate[]
  applications   ProgramApplication[]
  channelIdentities ChannelIdentity[]

  @@index([email])
  @@index([externalId])
}

// ── Sessions ─────────────────────────────────────────────────────────────────

model Session {
  id             String    @id @default(cuid())
  userId         String?
  channel        String    @default("web")
  language       String    @default("en")
  title          String?
  metadata       Json?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages       Message[]

  @@index([userId, isActive])
}

// ── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id             String      @id @default(cuid())
  sessionId      String
  role           MessageRole
  content        String
  language       String?
  toolName       String?     // If role=tool, which tool produced this
  toolCallId     String?     // Correlation ID for tool calls
  metadata       Json?       // Token counts, latency, model used, etc.
  createdAt      DateTime    @default(now())

  session        Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

// ── Memory (long-term user facts) ────────────────────────────────────────────

model Memory {
  id             String    @id @default(cuid())
  userId         String
  key            String    // e.g., "preferred_language", "name", "interests"
  value          String
  source         String?   // How was this learned? "conversation", "profile", etc.
  confidence     Float     @default(1.0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

// ── Knowledge: Indexed Sources ───────────────────────────────────────────────

model IndexedSource {
  id             String    @id @default(cuid())
  name           String    // e.g., "EdLight Academy"
  type           String    // github_repo | website | document | manual
  url            String?
  owner          String?   // GitHub org/user
  repo           String?   // GitHub repo name
  branch         String?   @default("main")
  lastIndexedAt  DateTime?
  status         String    @default("pending") // pending | indexing | indexed | error
  documentCount  Int       @default(0)
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // documents relation removed — IndexedDocument.sourceId is now a repo full name,
  // not a cuid referencing this table. Relationship managed by application code.

  @@unique([type, url])
  @@index([status])
}

// ── Knowledge: Indexed Documents ─────────────────────────────────────────────

model IndexedDocument {
  id             String    @id @default(cuid())
  sourceId       String    // Repo full name (e.g. "edlinitiative/code") — no FK
  title          String?
  path           String?   // File path or URL path within the source
  content        String    // Raw text content
  chunkIndex     Int       @default(0) // Position in chunked sequence
  chunkTotal     Int       @default(1) // Total chunks for this document
  contentHash    String?   // For dedup / change detection
  // Stored as pgvector vector(1536) — use raw SQL for similarity search.
  // Prisma reads/writes via Unsupported("vector(1536)"); use $queryRaw for search.
  embedding      Unsupported("vector(1536)")?
  metadata       Json?     // Extra fields: language, section, etc.
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // FK removed — sourceId is now the repo full name, not an IndexedSource cuid.
  // Relationship managed by application code; see PgVectorStore and indexer.

  @@index([sourceId])
  @@index([contentHash])
  @@index([sourceId, contentHash])
  @@index([path])
}

// ── Repo Registry ────────────────────────────────────────────────────────────

model RepoRegistry {
  id             String     @id @default(cuid())
  owner          String     // GitHub org or user
  name           String     // Repo name
  displayName    String     // Human-friendly name
  description    String?
  url            String
  branch         String     @default("main")
  docsPath       String?    // Path within repo to docs, e.g., "docs/"
  isActive       Boolean    @default(true)
  lastSyncAt     DateTime?
  syncStatus     SyncStatus @default(not_indexed)
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([owner, name])
  @@index([isActive])
}

// ── Enrollments ──────────────────────────────────────────────────────────────

model Enrollment {
  id             String    @id @default(cuid())
  userId         String
  courseId        String    // Platform-specific course identifier
  courseName     String
  platform       String    // "academy" | "code"
  status         String    @default("active") // active | completed | dropped
  enrolledAt     DateTime  @default(now())
  completedAt    DateTime?
  metadata       Json?

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
}

// ── Certificates ─────────────────────────────────────────────────────────────

model Certificate {
  id             String    @id @default(cuid())
  userId         String
  courseName     String
  platform       String    // "academy" | "code"
  issuedAt       DateTime  @default(now())
  certificateUrl String?
  metadata       Json?

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Program Applications ─────────────────────────────────────────────────────

model ProgramApplication {
  id             String    @id @default(cuid())
  userId         String
  programName    String    // e.g., "ESLP", "Nexus", "Academy Scholarship"
  programId      String?
  status         String    @default("submitted") // submitted | under_review | accepted | rejected | waitlisted
  appliedAt      DateTime  @default(now())
  reviewedAt     DateTime?
  metadata       Json?

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([programId])
}

// ── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id             String    @id @default(cuid())
  userId         String?
  sessionId      String?
  action         String    // tool_execution | permission_denied | auth_failure | data_access
  resource       String?   // Tool name, endpoint, etc.
  details        Json?
  ip             String?
  success        Boolean   @default(true)
  createdAt      DateTime  @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([action])
  @@index([createdAt])
}

// ── Channel Identity ─────────────────────────────────────────────────────────

model ActionRequest {
  id                String       @id @default(cuid())
  userId            String?
  sessionId         String?
  channel           String       @default("web")
  tool              String       // Which action tool was requested
  input             Json         // Serialised tool input
  status            ActionStatus @default(pending)
  requiresApproval  Boolean      @default(false)
  requestedAt       DateTime     @default(now())
  reviewedAt        DateTime?
  reviewedBy        String?      // userId of admin who reviewed
  reviewNote        String?      // Admin note on approval/rejection
  result            Json?        // Output after execution
  metadata          Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([userId])
  @@index([status])
  @@index([tool])
  @@index([requestedAt])
}

// ── Channel Identity ─────────────────────────────────────────────────────────

model ChannelIdentity {
  id             String    @id @default(cuid())
  userId         String
  channel        String    // 'whatsapp' | 'instagram' | 'email' | 'voice'
  externalId     String    // Phone (WhatsApp), PSID (Instagram), email address, etc.
  displayName    String?   // Name from the channel profile
  verified       Boolean   @default(false)
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channel, externalId])
  @@index([userId])
  @@index([channel])
}

// ── Analytics Events ─────────────────────────────────────────────────────────

model AnalyticsEvent {
  id         String   @id @default(cuid())
  eventType  String   // "message_sent" | "tool_executed" | "retrieval_completed" | "response_generated" | "session_started" | "cache_hit"
  sessionId  String?
  userId     String?
  channel    String?  // "web" | "whatsapp" | "instagram" | "email" | "voice"
  language   String?  // "en" | "fr" | "ht"
  data       Json?    // event-specific payload (tool name, latency, score, etc.)
  createdAt  DateTime @default(now())

  @@index([eventType])
  @@index([sessionId])
  @@index([userId])
  @@index([channel])
  @@index([createdAt])
}
