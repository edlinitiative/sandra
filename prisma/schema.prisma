// =============================================================================
// Sandra — Prisma Schema
// =============================================================================
// PostgreSQL-ready schema for the Sandra AI platform.
// Run `npx prisma db push` or `npx prisma migrate dev` to apply.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum MessageRole {
  user
  assistant
  system
  tool
}

enum SyncStatus {
  not_indexed
  indexing
  indexed
  error
}

enum ActionStatus {
  pending
  approved
  rejected
  executed
  failed
}

enum UserRole {
  guest
  student
  educator
  admin
}

// ── Users ────────────────────────────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  externalId     String?   @unique // ID from external auth provider
  name           String?
  email          String?   @unique
  role           UserRole  @default(guest)
  language       String    @default("en") // en | fr | ht
  channel        String    @default("web") // web | whatsapp | instagram | email | voice
  metadata       Json?     // Flexible extra data
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sessions       Session[]
  memories       Memory[]
  enrollments    Enrollment[]
  certificates   Certificate[]
  applications   ProgramApplication[]
  channelIdentities ChannelIdentity[]
  tenantMembers  TenantMember[]

  @@index([email])
  @@index([externalId])
}

// ── Sessions ─────────────────────────────────────────────────────────────────

model Session {
  id             String    @id @default(cuid())
  tenantId       String?
  userId         String?
  channel        String    @default("web")
  language       String    @default("en")
  title          String?
  metadata       Json?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages       Message[]

  @@index([tenantId])
  @@index([userId, isActive])
}

// ── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id             String      @id @default(cuid())
  tenantId       String?
  sessionId      String
  role           MessageRole
  content        String
  language       String?
  toolName       String?     // If role=tool, which tool produced this
  toolCallId     String?     // Correlation ID for tool calls
  metadata       Json?       // Token counts, latency, model used, etc.
  createdAt      DateTime    @default(now())

  tenant         Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session        Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sessionId])
  @@index([createdAt])
}

// ── Memory (long-term user facts) ────────────────────────────────────────────

model Memory {
  id             String    @id @default(cuid())
  tenantId       String?
  userId         String
  key            String    // e.g., "preferred_language", "name", "interests"
  value          String
  source         String?   // How was this learned? "conversation", "profile", etc.
  confidence     Float     @default(1.0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([tenantId])
  @@index([userId])
}

// ── Knowledge: Indexed Sources ───────────────────────────────────────────────

model IndexedSource {
  id             String    @id @default(cuid())
  tenantId       String?
  name           String    // e.g., "EdLight Academy"
  type           String    // github_repo | website | document | manual
  url            String?
  owner          String?   // GitHub org/user
  repo           String?   // GitHub repo name
  branch         String?   @default("main")
  lastIndexedAt  DateTime?
  status         String    @default("pending") // pending | indexing | indexed | error
  documentCount  Int       @default(0)
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // documents relation removed — IndexedDocument.sourceId is now a repo full name,
  // not a cuid referencing this table. Relationship managed by application code.

  @@unique([type, url])
  @@index([tenantId])
  @@index([status])
}

// ── Knowledge: Indexed Documents ─────────────────────────────────────────────

model IndexedDocument {
  id             String    @id @default(cuid())
  tenantId       String?
  sourceId       String    // Repo full name (e.g. "edlinitiative/code") — no FK
  title          String?
  path           String?   // File path or URL path within the source
  content        String    // Raw text content
  chunkIndex     Int       @default(0) // Position in chunked sequence
  chunkTotal     Int       @default(1) // Total chunks for this document
  contentHash    String?   // For dedup / change detection
  // Stored as pgvector vector(1536) — use raw SQL for similarity search.
  // Prisma reads/writes via Unsupported("vector(1536)"); use $queryRaw for search.
  embedding      Unsupported("vector(1536)")?
  metadata       Json?     // Extra fields: language, section, etc.
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // FK removed — sourceId is now the repo full name, not an IndexedSource cuid.
  // Relationship managed by application code; see PgVectorStore and indexer.

  @@index([tenantId])
  @@index([sourceId])
  @@index([contentHash])
  @@index([sourceId, contentHash])
  @@index([path])
}

// ── Repo Registry ────────────────────────────────────────────────────────────

model RepoRegistry {
  id             String     @id @default(cuid())
  tenantId       String?
  owner          String     // GitHub org or user
  name           String     // Repo name
  displayName    String     // Human-friendly name
  description    String?
  url            String
  branch         String     @default("main")
  docsPath       String?    // Path within repo to docs, e.g., "docs/"
  isActive       Boolean    @default(true)
  lastSyncAt     DateTime?
  syncStatus     SyncStatus @default(not_indexed)
  metadata       Json?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  tenant         Tenant?    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([owner, name])
  @@index([tenantId])
  @@index([isActive])
}

// ── Enrollments ──────────────────────────────────────────────────────────────

model Enrollment {
  id             String    @id @default(cuid())
  tenantId       String?
  userId         String
  courseId        String    // Platform-specific course identifier
  courseName     String
  platform       String    // "academy" | "code"
  status         String    @default("active") // active | completed | dropped
  enrolledAt     DateTime  @default(now())
  completedAt    DateTime?
  metadata       Json?

  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([courseId])
}

// ── Certificates ─────────────────────────────────────────────────────────────

model Certificate {
  id             String    @id @default(cuid())
  tenantId       String?
  userId         String
  courseName     String
  platform       String    // "academy" | "code"
  issuedAt       DateTime  @default(now())
  certificateUrl String?
  metadata       Json?

  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
}

// ── Program Applications ─────────────────────────────────────────────────────

model ProgramApplication {
  id             String    @id @default(cuid())
  tenantId       String?
  userId         String
  programName    String    // e.g., "ESLP", "Nexus", "Academy Scholarship"
  programId      String?
  status         String    @default("submitted") // submitted | under_review | accepted | rejected | waitlisted
  appliedAt      DateTime  @default(now())
  reviewedAt     DateTime?
  metadata       Json?

  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([programId])
}

// ── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id             String    @id @default(cuid())
  tenantId       String?
  userId         String?
  sessionId      String?
  action         String    // tool_execution | permission_denied | auth_failure | data_access
  resource       String?   // Tool name, endpoint, etc.
  details        Json?
  ip             String?
  success        Boolean   @default(true)
  createdAt      DateTime  @default(now())

  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([sessionId])
  @@index([action])
  @@index([createdAt])
}

// ── Action Requests ──────────────────────────────────────────────────────────

model ActionRequest {
  id                String       @id @default(cuid())
  tenantId          String?
  userId            String?
  sessionId         String?
  channel           String       @default("web")
  tool              String       // Which action tool was requested
  input             Json         // Serialised tool input
  status            ActionStatus @default(pending)
  requiresApproval  Boolean      @default(false)
  requestedAt       DateTime     @default(now())
  reviewedAt        DateTime?
  reviewedBy        String?      // userId of admin who reviewed
  reviewNote        String?      // Admin note on approval/rejection
  result            Json?        // Output after execution
  metadata          Json?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant            Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([tool])
  @@index([requestedAt])
}

// ── Channel Identity ─────────────────────────────────────────────────────────

model ChannelIdentity {
  id             String    @id @default(cuid())
  tenantId       String?
  userId         String
  channel        String    // 'whatsapp' | 'instagram' | 'email' | 'voice'
  externalId     String    // Phone (WhatsApp), PSID (Instagram), email address, etc.
  displayName    String?   // Name from the channel profile
  verified       Boolean   @default(false)
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant         Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channel, externalId])
  @@index([tenantId])
  @@index([userId])
  @@index([channel])
}

// ── Response Feedback ─────────────────────────────────────────────────────────

model MessageFeedback {
  id          String   @id @default(cuid())
  tenantId    String?
  sessionId   String
  userId      String?
  messageRef  String   // Client-assigned UUID for the response message
  rating      String   // 'up' | 'down'
  comment     String?  // Optional free-text from user
  metadata    Json?    // e.g. toolsUsed, retrievalUsed, responseSnippet
  createdAt   DateTime @default(now())

  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sessionId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
}

// ── Analytics Events ─────────────────────────────────────────────────────────

model AnalyticsEvent {
  id         String   @id @default(cuid())
  tenantId   String?
  eventType  String   // "message_sent" | "tool_executed" | "retrieval_completed" | "response_generated" | "session_started" | "cache_hit"
  sessionId  String?
  userId     String?
  channel    String?  // "web" | "whatsapp" | "instagram" | "email" | "voice"
  language   String?  // "en" | "fr" | "ht"
  data       Json?    // event-specific payload (tool name, latency, score, etc.)
  createdAt  DateTime @default(now())

  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([eventType])
  @@index([sessionId])
  @@index([userId])
  @@index([channel])
  @@index([createdAt])
}

// ── Learning Signals ──────────────────────────────────────────────────────────

/**
 * Recorded when a user corrects a prior Sandra response.
 * Admins review these to patch the knowledge base or fix retrieval gaps.
 */
model KnowledgeCorrection {
  id            String   @id @default(cuid())
  tenantId      String?
  sessionId     String
  userId        String?
  language      String?
  userMessage   String   // The correction message from the user (max 1000 chars)
  priorResponse String?  // The assistant response being corrected (max 500 chars)
  patterns      String[] // Matched pattern labels, e.g. ["en:thats_wrong"]
  reviewed      Boolean  @default(false)
  createdAt     DateTime @default(now())

  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sessionId])
  @@index([userId])
  @@index([reviewed])
  @@index([createdAt])
}

/**
 * Recorded when a user makes an action-oriented request but Sandra uses no tools.
 * Patterns like "please send", "can you create", "schedule a meeting" with zero
 * tool executions signal a capability Sandra doesn't yet have.
 * Admins review these to prioritise new tool development.
 */
model CapabilityGap {
  id          String   @id @default(cuid())
  tenantId    String?
  sessionId   String
  userId      String?
  channel     String?
  language    String?
  userMessage String   // The unmet request (max 1000 chars)
  patterns    String[] // Matched action-pattern labels
  reviewed    Boolean  @default(false)
  createdAt   DateTime @default(now())

  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sessionId])
  @@index([userId])
  @@index([reviewed])
  @@index([createdAt])
}

// ── Multi-Tenant ─────────────────────────────────────────────────────────

enum TenantRole {
  basic    // View knowledge, use chat — no org-level actions
  manager  // Manage knowledge sources, view team activity
  admin    // Full control: connect providers, manage members, audit
}

enum ProviderType {
  google_workspace
  microsoft_365
  zoom
  custom_api
  ai_openai
  ai_gemini
  ai_anthropic
  github
  whatsapp
  instagram
  brave_search
}

model Tenant {
  id          String   @id @default(cuid())
  name        String   // "EdLight", "Acme Corp"
  slug        String   @unique // "edlight", "acme-corp"  — URL-safe identifier
  domain      String?  @unique // "edlight.org" — for auto-matching users
  isActive    Boolean  @default(true)
  metadata    Json?    // Billing plan, feature flags, etc.
  agentConfig Json?    // TenantAgentConfig — AI identity, tool context, branding per tenant
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members            TenantMember[]
  providers          ConnectedProvider[]
  dynamicTools       DynamicTool[]
  apiConnections     ExternalApiConnection[]
  apiKeys            TenantApiKey[]
  sessions           Session[]
  messages           Message[]
  memories           Memory[]
  indexedSources     IndexedSource[]
  indexedDocuments   IndexedDocument[]
  repoRegistries     RepoRegistry[]
  enrollments        Enrollment[]
  certificates       Certificate[]
  applications       ProgramApplication[]
  auditLogs          AuditLog[]
  actionRequests     ActionRequest[]
  channelIdentities  ChannelIdentity[]
  messageFeedback    MessageFeedback[]
  analyticsEvents    AnalyticsEvent[]
  knowledgeCorrections KnowledgeCorrection[]
  capabilityGaps     CapabilityGap[]

  @@index([slug])
  @@index([domain])
}

model TenantMember {
  id         String     @id @default(cuid())
  tenantId   String
  userId     String
  role       TenantRole @default(basic)
  isActive   Boolean    @default(true)
  metadata   Json?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId, role])
}

model ConnectedProvider {
  id                String       @id @default(cuid())
  tenantId          String
  provider          ProviderType
  label             String?      // "Google Workspace — EdLight" (human-friendly)
  // Encrypted credentials blob (service account key, OAuth tokens, etc.)
  credentials       Json
  // Provider-specific configuration (Drive folder IDs, domain, scopes)
  config            Json?
  isActive          Boolean      @default(true)
  lastHealthCheck   DateTime?
  lastHealthStatus  String?      // "connected" | "disconnected" | "degraded"
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@index([provider])
}

// ── Dynamic Tool System ───────────────────────────────────────────────────────

/// A tool generated at runtime by the scaffoldTool meta-tool.
/// The handlerCode is plain JavaScript (no TypeScript) that gets eval'd and
/// hot-registered in the tool registry without a server restart.
model DynamicTool {
  id            String   @id @default(cuid())
  name          String   @unique
  description   String
  /// JSON Schema for the tool's input parameters
  parameters    Json
  /// Plain JS async function body (no TypeScript). Globals: fetch, executeTool.
  handlerCode   String   @db.Text
  requiredScopes String[]
  enabled       Boolean  @default(true)
  tested        Boolean  @default(false)
  /// userId of the admin who created this tool
  createdBy     String?
  /// CapabilityGap IDs that triggered this tool's creation
  sourceGapIds  String[]
  /// Tenant that owns this tool. NULL = global (legacy/scaffold-generated).
  tenantId      String?
  /// ExternalApiConnection this tool was generated from. NULL = scaffolded/manual.
  apiConnectionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apiConnection ExternalApiConnection? @relation(fields: [apiConnectionId], references: [id], onDelete: SetNull)

  @@index([enabled])
  @@index([createdAt])
  @@index([tenantId, enabled])
}

// ── External API Connections (Tool Registry Layer 2) ──────────────────────────

/// An external API that a tenant has registered with Sandra.
/// Sandra parses the OpenAPI spec and generates DynamicTool rows for each endpoint.
model ExternalApiConnection {
  id            String   @id @default(cuid())
  tenantId      String
  /// Human-readable name: "Acme CRM API", "Support Desk"
  name          String
  /// Base URL for all API calls: "https://api.acme.com/v1"
  baseUrl       String
  /// The original OpenAPI 3.x spec (JSON). Stored for re-parsing on updates.
  openApiSpec   Json?
  /// Auth method: "api_key" | "bearer" | "oauth2" | "basic" | "none"
  authType      String   @default("api_key")
  /// Encrypted credentials: { apiKey, bearerToken, clientId/secret, username/password }
  credentials   Json     @default("{}")
  /// Auth header/param config: { headerName: "X-API-Key", queryParam: "key" }
  authConfig    Json?
  /// Custom headers to send with every request: { "X-Tenant-Id": "acme-123" }
  defaultHeaders Json?
  /// Rate limit: max requests per minute. 0 = unlimited.
  rateLimitRpm  Int      @default(60)
  isActive      Boolean  @default(true)
  lastHealthCheck   DateTime?
  lastHealthStatus  String?  // "connected" | "error" | "unknown"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tools         DynamicTool[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
}

// ── Tenant API Keys (Sandra-as-API) ──────────────────────────────────────────

/// An API key that allows external callers to use Sandra on behalf of a tenant.
/// The plaintext key is only returned at creation time and NEVER stored.
/// keyHash  = SHA-256(plaintext) — used for lookup.
/// keyPrefix = first 12 chars of plaintext — shown in the admin UI for identification.
model TenantApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  /// Human-readable label: "Production", "Staging", "Website widget"
  name        String
  /// SHA-256 of the full plaintext key (hex). Never store plaintext.
  keyHash     String    @unique
  /// First 12 chars of plaintext for display. E.g. "sk_live_a1b2"
  keyPrefix   String
  /// Scopes granted to this key: ["chat:send", "knowledge:read", …]
  scopes      String[]  @default(["chat:send", "knowledge:read"])
  isActive    Boolean   @default(true)
  /// Optional hard expiry. NULL = no expiry.
  expiresAt   DateTime?
  /// Updated on each successful use (rate limiting / audit).
  lastUsedAt  DateTime?
  createdBy   String?   // userId of the admin who created it
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@index([keyHash])
}
